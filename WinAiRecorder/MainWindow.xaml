<Window x:Class="WinAiRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win AI Recorder"
        Width="100" Height="130"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Pulse animation for recording state -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="MicButton"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.5" Duration="0:0:0.7"
                             AutoReverse="True"/>
        </Storyboard>

        <!-- Spinner animation for processing state -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerEllipse"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1"/>
        </Storyboard>

        <!-- Success fade animation -->
        <Storyboard x:Key="SuccessFade">
            <DoubleAnimation Storyboard.TargetName="SuccessIcon"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.0" Duration="0:0:1.5"
                             BeginTime="0:0:0.5"/>
        </Storyboard>

        <!-- Border flash animation for 9-min warning -->
        <Storyboard x:Key="WarnFlash" RepeatBehavior="5x">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.4" Duration="0:0:0.3" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <!-- Outer drop shadow container -->
    <Border Margin="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <!-- Main rounded container -->
        <Border x:Name="MainBorder"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                MouseLeftButtonDown="Window_MouseLeftButtonDown">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                </Grid.RowDefinitions>

                <!-- Mic button area -->
                <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Idle / Recording: Mic icon -->
                    <Button x:Name="MicButton"
                            Width="56" Height="56"
                            Click="MicButton_Click"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1.5"
                            Cursor="Hand"
                            ToolTip="Click or press hotkey to record">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="28"
                                        Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                        <!-- Microphone SVG path -->
                        <Viewbox Width="28" Height="28">
                            <Canvas Width="24" Height="24">
                                <Path x:Name="MicPath"
                                      Fill="{DynamicResource AccentBrush}"
                                      Data="M12,2A4,4 0 0,1 16,6V12A4,4 0 0,1 12,16A4,4 0 0,1 8,12V6A4,4 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Processing spinner (hidden by default) -->
                    <Grid x:Name="SpinnerGrid" Visibility="Collapsed" Width="56" Height="56">
                        <Ellipse x:Name="SpinnerEllipse"
                                 Width="44" Height="44"
                                 Stroke="{DynamicResource AccentBrush}"
                                 StrokeThickness="3"
                                 StrokeDashArray="8,4">
                            <Ellipse.RenderTransform>
                                <RotateTransform CenterX="22" CenterY="22"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>

                    <!-- Success checkmark (hidden by default) -->
                    <Grid x:Name="SuccessIcon" Visibility="Collapsed" Opacity="1">
                        <Ellipse Width="56" Height="56" Fill="{DynamicResource SuccessBrush}" Opacity="0.15"/>
                        <Viewbox Width="32" Height="32">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource SuccessBrush}"
                                      Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <!-- Error icon (hidden by default) -->
                    <Grid x:Name="ErrorIcon" Visibility="Collapsed">
                        <Viewbox Width="40" Height="40">
                            <Canvas Width="24" Height="24">
                                <Path x:Name="ErrorPath"
                                      Fill="{DynamicResource WarningBrush}"
                                      Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Grid>

                <!-- Audio waveform -->
                <Grid x:Name="WaveCanvas" Grid.Row="1"
                      Height="16" Width="80"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,2"
                      Visibility="Collapsed">
                    <Polyline x:Name="WaveLine"
                              Stroke="{DynamicResource RecordingBrush}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              VerticalAlignment="Top"
                              HorizontalAlignment="Left"/>
                </Grid>

                <!-- Status label (optional tooltip area) -->
                <TextBlock x:Name="StatusText"
                           Grid.Row="2"
                           Text=""
                           FontSize="8"
                           Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
            </Grid>
        </Border>
    </Border>

    <Window.ContextMenu>
        <ContextMenu x:Name="OverlayContextMenu">
            <MenuItem Header="Hide" Click="HideMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="Settings..." Click="SettingsMenuItem_Click"/>
            <MenuItem Header="Exit" Click="ExitMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
</Window>
