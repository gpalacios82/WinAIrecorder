<Window x:Class="VoiceType.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceType Settings"
        Width="420" Height="500"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="VoiceType Settings"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0,0,0,20"/>

        <!-- Settings content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- API Key section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Label Content="🔑  API Key"/>
                        <TextBlock x:Name="CurrentKeyText"
                                   Text="No key configured"
                                   FontSize="12"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="0,0,0,8"/>
                        <PasswordBox x:Name="ApiKeyBox"
                                     PasswordChar="●"/>
                        <TextBlock Text="Saved as OPENAI_API_KEY environment variable (user scope)"
                                   FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Model section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Label Content="🎙️  Transcription Model"/>
                        <ComboBox x:Name="ModelComboBox"/>
                        <TextBlock x:Name="ModelLoadingText"
                                   Text="Loading models from API..."
                                   FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Hotkey section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Label Content="⌨️  Global Hotkey"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HotkeyBox"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     Margin="0,0,8,0"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus"
                                     LostFocus="HotkeyBox_LostFocus"/>
                            <Button Grid.Column="1" Content="Reset"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ResetHotkey_Click" Width="60"/>
                        </Grid>
                        <TextBlock Text="Click the field and press your desired key combination"
                                   FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Options section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Label Content="⚙️  Options"/>
                        <CheckBox x:Name="ClipboardFallbackCheck"
                                  Content="Also copy to clipboard as fallback (for apps that don't accept SendInput)"/>
                        <CheckBox x:Name="AutoStartCheck"
                                  Content="Start VoiceType with Windows"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText" Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource SubtextBrush}"/>

            <Button Grid.Column="1" Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Width="80"
                    Click="Cancel_Click"/>

            <Button Grid.Column="3" Content="Save"
                    Width="80"
                    Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
